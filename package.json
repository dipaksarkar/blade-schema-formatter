{
  "name": "blade-schema-formatter",
  "displayName": "Blade Schema Formatter",
  "description": "",
  "publisher": "dipaksarkar",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.105.0"
  },
  "categories": [
    "Other"
  ],
  "repository": {},
